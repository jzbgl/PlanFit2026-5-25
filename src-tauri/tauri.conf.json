{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-config/main/schema.json",
  "productName": "PlanFit",
  "version": "0.1.0",
  "identifier": "com.planfit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PlanFit",
        "width": 1024,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  }
}
